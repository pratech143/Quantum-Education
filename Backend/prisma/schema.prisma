generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPERADMIN
  ADMIN
}

enum InstitutionType {
  UNIVERSITY
  COLLEGE
}

model AdminUser {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  password            String
  role                AdminRole @default(ADMIN)
  isActive            Boolean   @default(true)
  forcePasswordChange Boolean   @default(false)
  createdById         String?
  createdBy           AdminUser?  @relation("AdminCreatedBy", fields: [createdById], references: [id])
  createdAdmins       AdminUser[] @relation("AdminCreatedBy")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([email])
  @@index([role])
}

model ContactRequest {
  id                   String   @id @default(cuid())
  fullName             String
  email                String
  phoneNumber          String?
  preferredDestination String?
  message              String
  createdAt            DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model Country {
  id           String   @id @default(uuid())
  name         String   @unique
  slug         String   @unique
  description  String
  tuitionFees  Float
  visaInfo     String
  livingCost   Float
  currency     String

  // Hero section
  heroImage    String?
  heroSubtitle String?
  heroStats    Json?    // [{ label: string, value: string }]

  // Overview section
  overview     Json?    // { title: string, description: string[] }

  // Details grid
  details      Json?    // [{ icon: string, title: string, description: string }]

  // Popular courses
  popularCourses Json?  // [{ title: string, icon: string, desc: string }]

  // Admission requirements
  admissionRequirements Json? // string[]

  // Intakes
  intakes      Json?    // [{ name: string, month: string }]

  // Scholarships
  scholarships Json?    // { description: string }

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  universities University[]

  @@index([name])
  @@index([slug])
}

model University {
  id          String          @id @default(uuid())
  name        String
  slug        String          @unique
  description String
  location    String?
  image       String?
  ranking     Int
  qsRanking   String?
  tagline     String?
  website     String
  type        InstitutionType @default(UNIVERSITY)
  fees        String?

  // Rich detail sections (JSON for flexibility)
  heroData      Json?  // { title, subtitle, image, primaryCta, secondaryCta }
  whySection    Json?  // { title, reasons: [{ icon, title, description, link?, linkText? }] }
  coursesData   Json?  // { title, description, buttonText, courses: [{ icon, title, description, tag?, tagStyle? }] }
  admissionData Json?  // { requirementsTitle, howToApplyTitle, requirements: [{ title, description }], howToApply: string[] }

  countryId   String
  country     Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([countryId])
  @@index([name])
  @@index([slug])
  @@index([type])
}

model Alumni {
  id         String   @id @default(uuid())
  name       String
  university String
  degree     String
  country    String
  quote      String
  image      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([country])
}

enum NewsLabel {
  news
  notice
}

model News {
  id            String    @id @default(cuid())
  headTitle     String
  subtitle      String
  label         NewsLabel @default(news)
  description   String
  image         String?
  date          DateTime  @default(now())
  author        String?
  authorRole    String?
  authorImage   String?
  caption       String?
  readTime      String?
  content       Json?     // [{ type: 'paragraph' | 'heading' | 'list', value: string | string[] }]
  phases        Json?     // string[]
  pullQuote     Json?     // { text: string, source: string }
  isRelatedOnly Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([label])
}
