PORT=4000
NODE_ENV=development
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:5173
CONTACT_RATE_LIMIT_WINDOW_MS=900000
CONTACT_RATE_LIMIT_MAX=5
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
ADMIN_JWT_SECRET=replace-with-a-random-secret-32-chars-min
# ── Gmail SMTP ──────────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an App Password (select "Mail" → "Other")
# 4. Paste the 16-character password below (no spaces)
CONTACT_NOTIFICATION_TO_EMAIL=owner@example.com
CONTACT_NOTIFICATION_SUBJECT=New website lead received
ADMIN_PANEL_URL=https://your-admin-panel-url.example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM_EMAIL=your-email@gmail.com
